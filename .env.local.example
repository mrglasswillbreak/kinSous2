# Vercel Neon PostgreSQL connection string
# Get this from: https://console.neon.tech → your project → Connection string
DATABASE_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Secret key for session token signing (use a long random string in production)
# Generate one with: openssl rand -base64 32
AUTH_SECRET=your-secret-key-here
